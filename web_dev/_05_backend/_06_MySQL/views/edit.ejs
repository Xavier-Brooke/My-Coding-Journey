<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit</title>
</head>
<body>
    <h1><i>Edit your post :- </i></h1>
    <form method="post" action="/users/<%= result[0].userId %>?_method=PATCH">
        <label for="username">Edit your username :- </label>
        <input type="text" id="username" name="username" required maxlength="50" value="<%= result[0].username %>">
        <br><br>
        <label for="email">Edit your email :- </label>
        <input type="text" id="email" name="email" required maxlength="50" value="<%= result[0].email %>">
        <br><br>
        <label for="password">Edit your password :- </label>
        <input type="text" id="password" name="password" required maxlength="50" value="<%= result[0].password %>">
        <br><br>
        <button>Submit</button>
    </form>
</body>
</html>